# Core .gitignore for Shell Scripting

# Environment variables / Secrets
.env
.env.local
*.env

# Temporary files and backups
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Log files and debug dumps
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Crash reports
pid
*.pid
*.seed
*.pid.lock

# Test coverage results
.coverage
htmlcov/
test.csv
values.txt
